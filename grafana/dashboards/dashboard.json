{
  "id": null,
  "uid": "adnl62w",
  "title": "App Dashboard",
  "tags": [
    "resume-review",
    "platform"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "templating": {
    "list": []
  },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "Outbound Data (KB/s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-db"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_request_size_bytes_sum[5m])) / 1024",
          "legendFormat": "outbound"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Requests Per Second (5m)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-db"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total[5m]))",
          "legendFormat": "rps"
        }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "99th Percentile Latency (s)",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus-db"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Total Users",
      "datasource": {
        "type": "postgres",
        "uid": "postgres-db"
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 12,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT now() AS \"time\", count(*) FROM users;"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Total Resumes",
      "datasource": {
        "type": "postgres",
        "uid": "postgres-db"
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 16,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT now() AS \"time\", count(*) FROM resumes;"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 6,
      "type": "stat",
      "title": "Total Comments",
      "datasource": {
        "type": "postgres",
        "uid": "postgres-db"
      },
      "gridPos": {
        "h": 8,
        "w": 4,
        "x": 20,
        "y": 8
      },
      "targets": [
        {
          "refId": "A",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT now() AS \"time\", count(*) FROM comments;"
        }
      ],
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto"
      }
    }
  ]
}
